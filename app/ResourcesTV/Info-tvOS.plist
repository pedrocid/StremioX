<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Base Info.plist (Xcode merges its generated keys on top). The ATS exception lets the
	     native client's URLSession reach the embedded streaming server at http://127.0.0.1:11470
	     (cleartext loopback) to create torrents. libmpv playback isn't ATS-governed. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
